# Maven profile for Java module builds
LR_BUILD_PROFILE=lareferencia

# Build jars policy on container startup: smart|always|false
BUILD_ON_START=smart

# Optional modules enabled by default in Docker/dev.sh
DEV_MODULE_VUFIND=off
DEV_MODULE_ELASTIC=off
DEV_MODULE_WATCH=off

# VuFind checkout (used when ./vufind is missing)
VUFIND_REPO_URL=https://github.com/vufind-org/vufind
VUFIND_REF=v11.0.1

# VuFind theme (optional)
VUFIND_THEME=bootstrap5

# VuFind debug mode (default OFF)
VUFIND_ENV=production
VUFIND_SYSTEM_DEBUG=false
VUFIND_PHP_DISPLAY_ERRORS=0
VUFIND_PHP_DISPLAY_STARTUP_ERRORS=0
VUFIND_PHP_ERROR_REPORTING=E_ALL
VUFIND_PHP_HTML_ERRORS=0
