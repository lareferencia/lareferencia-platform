SERVICE_PREFIX=
SERVICES_PORT_OFFSET=

# Maven profile for Java module builds
LR_BUILD_PROFILE=lareferencia

# External services configuration
# If SOLR_EXTERNAL_URL is set, the local Docker Solr container will not be started.
# Example: http://your-external-solr-host:8983/solr
SOLR_EXTERNAL_URL=

# Build jars policy on container startup: smart|always|false
BUILD_ON_START=smart

# Keep shell service container idle/running and execute commands via docker exec
SHELL_IDLE=true

# Optional modules enabled by default in Docker/docker.sh
DEV_MODULE_SOLR=on
DEV_MODULE_HARVESTER=on
DEV_MODULE_DASHBOARD=off
DEV_MODULE_ENTITY_REST=off
DEV_MODULE_SHELL=off
DEV_MODULE_VUFIND=on
DEV_MODULE_ELASTIC=off
DEV_MODULE_WATCH=off

# VuFind checkout (used when ./vufind is missing)
VUFIND_REPO_URL=https://github.com/LA-Referencia-IOI/vufind
VUFIND_REF=v11.0.1

# VuFind theme (optional)
VUFIND_THEME=bootstrap5

# VuFind debug mode (default OFF)
VUFIND_ENV=production
VUFIND_SYSTEM_DEBUG=false
VUFIND_PHP_DISPLAY_ERRORS=0
VUFIND_PHP_DISPLAY_STARTUP_ERRORS=0
VUFIND_PHP_ERROR_REPORTING=E_ALL
VUFIND_PHP_HTML_ERRORS=0
