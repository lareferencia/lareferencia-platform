#!/usr/bin/env python3
"""githelper: unified Git workspace workflow CLI."""

from __future__ import annotations

import argparse
import configparser
import re
import shutil
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Dict, Iterable, List, Mapping, Optional, Sequence


MANIFEST_FILE = "workspace.ini"


@dataclass
class CommandResult:
    returncode: int
    stdout: str
    stderr: str


@dataclass
class ModuleMeta:
    name: str
    path: str
    url: str
    branch: str


@dataclass
class Workspace:
    default_branch: str
    modules: List[ModuleMeta]
    profiles: Dict[str, Dict[str, str]]

    def module_by_selector(self) -> Dict[str, ModuleMeta]:
        selectors: Dict[str, ModuleMeta] = {}
        for module in self.modules:
            selectors[module.name] = module
            selectors[module.path] = module
        return selectors


@dataclass
class MigrationItem:
    module: ModuleMeta
    git_file: Path
    gitdir: Path
    destination: Path


def run_git(args: Sequence[str], cwd: Path) -> CommandResult:
    return run_command(["git", *args], cwd)


def run_command(args: Sequence[str], cwd: Path) -> CommandResult:
    try:
        proc = subprocess.run(
            list(args),
            cwd=str(cwd),
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )
    except FileNotFoundError as exc:
        return CommandResult(127, "", str(exc))
    return CommandResult(proc.returncode, proc.stdout.strip(), proc.stderr.strip())


def fail(message: str, code: int = 1) -> int:
    print(f"ERROR: {message}", file=sys.stderr)
    return code


def warn(message: str) -> None:
    print(f"WARN: {message}")


def info(message: str) -> None:
    print(message)


def get_repo_root() -> Path:
    result = run_git(["rev-parse", "--show-toplevel"], Path.cwd())
    if result.returncode != 0 or not result.stdout:
        raise RuntimeError("This command must run inside a git repository.")
    return Path(result.stdout)


def get_current_branch(repo: Path) -> Optional[str]:
    result = run_git(["symbolic-ref", "--quiet", "--short", "HEAD"], repo)
    if result.returncode != 0:
        return None
    return result.stdout.strip() or None


def is_git_repository(repo: Path) -> bool:
    if not repo.exists():
        return False
    result = run_git(["rev-parse", "--show-toplevel"], repo)
    if result.returncode != 0 or not result.stdout.strip():
        return False
    try:
        return Path(result.stdout.strip()).resolve() == repo.resolve()
    except OSError:
        return False


def local_branch_exists(repo: Path, branch: str) -> bool:
    result = run_git(["show-ref", "--verify", "--quiet", f"refs/heads/{branch}"], repo)
    return result.returncode == 0


def remote_branch_exists(repo: Path, branch: str) -> bool:
    result = run_git(["show-ref", "--verify", "--quiet", f"refs/remotes/origin/{branch}"], repo)
    return result.returncode == 0


def ensure_remote_refs(repo: Path) -> CommandResult:
    return run_git(["fetch", "--prune", "origin"], repo)


def working_tree_dirty(repo: Path) -> bool:
    result = run_git(["status", "--porcelain"], repo)
    if result.returncode != 0:
        return False
    return bool(result.stdout.strip())


def working_tree_status(repo: Path) -> str:
    result = run_git(["status", "--porcelain"], repo)
    if result.returncode != 0:
        return "status?"

    lines = [line for line in result.stdout.splitlines() if line.strip()]
    if not lines:
        return "clean"
    return f"dirty:{len(lines)}"


def manifest_path(root: Path) -> Path:
    return root / MANIFEST_FILE


def read_manifest_parser(root: Path) -> configparser.ConfigParser:
    path = manifest_path(root)
    if not path.exists():
        raise RuntimeError(f"{MANIFEST_FILE} not found in {root}.")

    parser = configparser.ConfigParser(interpolation=None)
    parser.optionxform = str
    read_files = parser.read(path)
    if not read_files:
        raise RuntimeError(f"Could not read {MANIFEST_FILE}.")
    return parser


def write_manifest_parser(root: Path, parser: configparser.ConfigParser) -> None:
    with manifest_path(root).open("w", encoding="utf-8") as fh:
        parser.write(fh)


def validate_module_path(path: str) -> None:
    module_path = Path(path)
    if module_path.is_absolute():
        raise RuntimeError(f"Module path must be relative: {path}")
    if ".." in module_path.parts:
        raise RuntimeError(f"Module path must stay inside the workspace: {path}")


def load_workspace(root: Path) -> Workspace:
    parser = read_manifest_parser(root)
    default_branch = parser.get("workspace", "default_branch", fallback="main").strip() or "main"

    modules: List[ModuleMeta] = []
    for section in parser.sections():
        if not section.startswith("module."):
            continue

        name = section[len("module.") :].strip()
        if not name:
            raise RuntimeError(f"Invalid empty module section in {MANIFEST_FILE}.")

        path = parser.get(section, "path", fallback=name).strip() or name
        validate_module_path(path)

        url = parser.get(section, "url", fallback="").strip()
        if not url:
            raise RuntimeError(f"{section} must define url.")

        branch = parser.get(section, "branch", fallback=default_branch).strip() or default_branch
        modules.append(ModuleMeta(name=name, path=path, url=url, branch=branch))

    if not modules:
        raise RuntimeError(f"{MANIFEST_FILE} does not define any [module.*] sections.")

    profiles: Dict[str, Dict[str, str]] = {}
    for section in parser.sections():
        if not section.startswith("profile."):
            continue
        profile_name = section[len("profile.") :].strip()
        if not profile_name:
            raise RuntimeError(f"Invalid empty profile section in {MANIFEST_FILE}.")

        profile: Dict[str, str] = {}
        for module_name, branch in parser.items(section):
            module_name = module_name.strip()
            branch = branch.strip()
            if module_name and branch:
                profile[module_name] = branch
        profiles[profile_name] = profile

    return Workspace(default_branch=default_branch, modules=modules, profiles=profiles)


def parse_modules_arg(raw_modules: Optional[str]) -> List[str]:
    if not raw_modules:
        return []

    parsed: List[str] = []
    for token in raw_modules.replace(",", " ").split():
        token = token.strip()
        if token:
            parsed.append(token)

    deduped: List[str] = []
    seen = set()
    for module in parsed:
        if module not in seen:
            seen.add(module)
            deduped.append(module)
    return deduped


def select_modules(workspace: Workspace, raw_modules: Optional[str]) -> List[ModuleMeta]:
    requested = parse_modules_arg(raw_modules)
    if not requested:
        return workspace.modules

    by_selector = workspace.module_by_selector()
    missing = [name for name in requested if name not in by_selector]
    if missing:
        available = ", ".join(module.name for module in workspace.modules)
        raise RuntimeError("Unknown modules: " + ", ".join(missing) + ". Available: " + available)

    return [by_selector[name] for name in requested]


def target_branch_for_module(workspace: Workspace, profile_name: Optional[str], module: ModuleMeta) -> str:
    profile = workspace.profiles.get(profile_name or "")
    if profile:
        if module.name in profile:
            return profile[module.name]
        if module.path in profile:
            return profile[module.path]
    return module.branch or workspace.default_branch


def target_branches(workspace: Workspace, profile_name: Optional[str], modules: Iterable[ModuleMeta]) -> Dict[str, str]:
    return {module.name: target_branch_for_module(workspace, profile_name, module) for module in modules}


def prompt_changes_policy(module: str) -> str:
    while True:
        try:
            answer = input(
                f"{module}: hay cambios sin commit. "
                "¿Qué quieres hacer? [l]levar a la nueva branch / [d]ejar en la branch actual: "
            ).strip().lower()
        except EOFError as exc:
            raise RuntimeError(
                f"{module}: no se pudo leer respuesta interactiva para resolver cambios locales."
            ) from exc
        if answer in ("l", "llevar"):
            return "carry"
        if answer in ("d", "dejar"):
            return "keep"
        print("Respuesta no válida. Usa 'l' (llevar) o 'd' (dejar).")


def url_to_https(url: str) -> Optional[str]:
    if url.startswith("https://"):
        return url

    scp_style = re.match(r"^[^@]+@([^:]+):(.+)$", url)
    if scp_style:
        host = scp_style.group(1)
        path = scp_style.group(2)
        return f"https://{host}/{path}"

    ssh_style = re.match(r"^ssh://(?:[^@/]+@)?([^/]+)/(.+)$", url)
    if ssh_style:
        host = ssh_style.group(1)
        path = ssh_style.group(2)
        return f"https://{host}/{path}"

    return None


def url_to_ssh(url: str) -> Optional[str]:
    scp_style = re.match(r"^[^@]+@([^:]+):(.+)$", url)
    if scp_style:
        return url

    ssh_style = re.match(r"^ssh://(?:[^@/]+@)?([^/]+)/(.+)$", url)
    if ssh_style:
        host = ssh_style.group(1)
        path = ssh_style.group(2)
        return f"git@{host}:{path}"

    https_style = re.match(r"^https://([^/]+)/(.+)$", url)
    if https_style:
        host = https_style.group(1)
        path = https_style.group(2)
        return f"git@{host}:{path}"

    return None


def rewrite_url(url: str, target: str) -> Optional[str]:
    if target == "https":
        return url_to_https(url)
    if target == "ssh":
        return url_to_ssh(url)
    return None


def switch_to_branch(repo: Path, branch: str) -> CommandResult:
    current = get_current_branch(repo)
    if current == branch:
        return CommandResult(0, f"Already on '{branch}'", "")

    if local_branch_exists(repo, branch):
        return run_git(["switch", branch], repo)

    if remote_branch_exists(repo, branch):
        return run_git(["switch", "-c", branch, "--track", f"origin/{branch}"], repo)

    return CommandResult(2, "", f"Branch '{branch}' not found locally or in origin")


def pull_repo(repo: Path) -> CommandResult:
    return run_git(["pull"], repo)


def format_branch(repo: Path) -> str:
    if not repo.exists():
        return "MISSING"
    if not is_git_repository(repo):
        return "UNINITIALIZED"
    branch = get_current_branch(repo)
    return branch if branch else "DETACHED"


def print_status(root: Path, modules: Iterable[ModuleMeta], dirty_only: bool = False) -> int:
    head = run_git(["rev-parse", "--short", "HEAD"], root)
    parent_branch = format_branch(root)
    parent_sha = head.stdout if head.returncode == 0 else "?"
    parent_state = working_tree_status(root)
    if not dirty_only or parent_state != "clean":
        info(f"parent | {parent_branch} | {parent_sha} | {parent_state}")

    for module in modules:
        repo = root / module.path
        branch_state = format_branch(repo)
        if branch_state in ("MISSING", "UNINITIALIZED"):
            if not dirty_only:
                info(f"{module.name} | {branch_state} | ? | status?")
            continue
        sha = run_git(["rev-parse", "--short", "HEAD"], repo)
        state = working_tree_status(repo)
        if dirty_only and state == "clean":
            continue
        info(f"{module.name} | {branch_state} | {sha.stdout if sha.returncode == 0 else '?'} | {state}")

    return 0


def cmd_status(args: argparse.Namespace) -> int:
    try:
        root = get_repo_root()
        workspace = load_workspace(root)
        modules = select_modules(workspace, args.modules)
    except RuntimeError as err:
        return fail(str(err))

    return print_status(root, modules, dirty_only=args.dirty)


def cmd_init(args: argparse.Namespace) -> int:
    try:
        root = get_repo_root()
        workspace = load_workspace(root)
        modules = select_modules(workspace, args.modules)
    except RuntimeError as err:
        return fail(str(err))

    cloned = 0
    existing = 0
    errors = 0

    for module in modules:
        repo = root / module.path
        branch = target_branch_for_module(workspace, args.branch, module) if args.branch else module.branch

        if repo.exists():
            if is_git_repository(repo):
                info(f"OK   {module.name}: repository already exists at {module.path}.")
                existing += 1
            else:
                warn(f"{module.name}: path exists but is not a git repository: {module.path}")
                errors += 1
            continue

        clone_result = run_git(["clone", "--branch", branch, module.url, module.path], root)
        if clone_result.returncode == 0:
            info(f"OK   {module.name}: cloned '{branch}' into {module.path}.")
            cloned += 1
        else:
            warn(f"{module.name}: clone failed for branch '{branch}': {clone_result.stderr or clone_result.stdout}")
            errors += 1

    info(f"Summary: cloned={cloned} existing={existing} errors={errors}")
    return 1 if errors else 0


def cmd_sync(args: argparse.Namespace) -> int:
    try:
        root = get_repo_root()
        workspace = load_workspace(root)
        modules = select_modules(workspace, args.modules)
    except RuntimeError as err:
        return fail(str(err))

    profile_name = args.branch or get_current_branch(root)
    if not profile_name:
        return fail("Parent repository is in detached HEAD; pass --branch explicitly.")

    switched = 0
    unchanged = 0
    errors = 0

    for module in modules:
        repo = root / module.path
        branch = target_branch_for_module(workspace, profile_name, module)
        if not repo.exists() or not is_git_repository(repo):
            warn(f"{module.name}: repository missing or uninitialized; run './githelper init'.")
            errors += 1
            continue

        fetch_result = ensure_remote_refs(repo)
        if fetch_result.returncode != 0:
            warn(f"{module.name}: fetch failed: {fetch_result.stderr or fetch_result.stdout}")
            errors += 1
            continue

        result = switch_to_branch(repo, branch)
        if result.returncode == 0:
            if result.stdout.startswith("Already on"):
                info(f"OK   {module.name}: already on '{branch}'.")
                unchanged += 1
            else:
                info(f"OK   {module.name}: now on '{branch}'.")
                switched += 1
        else:
            warn(f"{module.name}: required branch '{branch}' not found: {result.stderr or result.stdout}")
            errors += 1

    info(f"Summary: switched={switched} unchanged={unchanged} errors={errors}")
    return 1 if errors else 0


def cmd_switch(args: argparse.Namespace) -> int:
    try:
        root = get_repo_root()
        workspace = load_workspace(root)
        select_modules(workspace, args.modules)
    except RuntimeError as err:
        return fail(str(err))

    target = args.branch
    ensure_remote_refs(root)

    parent_result = switch_to_branch(root, target)
    if parent_result.returncode != 0:
        return fail(f"Could not switch parent to '{target}': {parent_result.stderr or parent_result.stdout}")

    info(f"OK   parent: now on '{target}'.")
    sync_ns = argparse.Namespace(branch=target, modules=args.modules)
    return cmd_sync(sync_ns)


def cmd_branch_create(args: argparse.Namespace) -> int:
    try:
        root = get_repo_root()
        workspace = load_workspace(root)
        modules = select_modules(workspace, args.modules)
    except RuntimeError as err:
        return fail(str(err))

    if not modules:
        return fail("No modules selected. Use --modules <m1,m2,...>.")

    branch = args.branch or get_current_branch(root)
    if not branch:
        return fail("Parent repository is in detached HEAD; pass --branch explicitly.")

    created = 0
    existing = 0
    kept_changes = 0
    errors = 0

    for module in modules:
        repo = root / module.path
        if not repo.exists() or not is_git_repository(repo):
            warn(f"{module.name}: repository missing or uninitialized; run './githelper init'.")
            errors += 1
            continue

        fetch_result = ensure_remote_refs(repo)
        if fetch_result.returncode != 0:
            warn(f"{module.name}: fetch failed: {fetch_result.stderr or fetch_result.stdout}")
            errors += 1
            continue

        dirty = working_tree_dirty(repo)
        if dirty:
            try:
                policy = prompt_changes_policy(module.name)
            except RuntimeError as err:
                return fail(str(err))
            if policy == "keep":
                if local_branch_exists(repo, branch):
                    info(
                        f"OK   {module.name}: branch '{branch}' ya existía. "
                        "Se mantienen cambios en la branch actual."
                    )
                    existing += 1
                    kept_changes += 1
                    continue

                if remote_branch_exists(repo, branch):
                    result = run_git(["branch", "--track", branch, f"origin/{branch}"], repo)
                    if result.returncode == 0:
                        info(
                            f"OK   {module.name}: branch local '{branch}' creada desde 'origin/{branch}'. "
                            "Cambios permanecen en la branch actual."
                        )
                        created += 1
                        kept_changes += 1
                    else:
                        warn(
                            f"{module.name}: no se pudo crear branch local '{branch}' "
                            f"sin cambiar de branch: {result.stderr or result.stdout}"
                        )
                        errors += 1
                    continue

                result = run_git(["branch", branch], repo)
                if result.returncode == 0:
                    info(
                        f"OK   {module.name}: branch '{branch}' creada desde HEAD actual. "
                        "Cambios permanecen en la branch actual."
                    )
                    created += 1
                    kept_changes += 1
                else:
                    warn(
                        f"{module.name}: no se pudo crear branch '{branch}' "
                        f"sin cambiar de branch: {result.stderr or result.stdout}"
                    )
                    errors += 1
                continue

        if local_branch_exists(repo, branch):
            result = run_git(["switch", branch], repo)
            if result.returncode == 0:
                info(f"OK   {module.name}: branch '{branch}' already existed, switched to it.")
                existing += 1
            else:
                warn(f"{module.name}: branch '{branch}' exists but switch failed: {result.stderr or result.stdout}")
                errors += 1
            continue

        if remote_branch_exists(repo, branch):
            result = run_git(["switch", "-c", branch, "--track", f"origin/{branch}"], repo)
            if result.returncode == 0:
                info(f"OK   {module.name}: created local tracking branch '{branch}'.")
                created += 1
            else:
                warn(f"{module.name}: could not create tracking branch '{branch}': {result.stderr or result.stdout}")
                errors += 1
            continue

        result = run_git(["switch", "-c", branch], repo)
        if result.returncode == 0:
            info(f"OK   {module.name}: created new branch '{branch}' from current HEAD.")
            created += 1
        else:
            warn(f"{module.name}: could not create branch '{branch}': {result.stderr or result.stdout}")
            errors += 1

    info(f"Summary: created={created} existing={existing} kept_changes={kept_changes} errors={errors}")
    return 1 if errors else 0


def cmd_pull(args: argparse.Namespace) -> int:
    try:
        root = get_repo_root()
        workspace = load_workspace(root)
        modules = select_modules(workspace, args.modules)
    except RuntimeError as err:
        return fail(str(err))

    if args.branch:
        ensure_remote_refs(root)
        switch_result = switch_to_branch(root, args.branch)
        if switch_result.returncode != 0:
            return fail(f"Could not switch parent to '{args.branch}': {switch_result.stderr or switch_result.stdout}")

    parent_branch = get_current_branch(root)
    if not parent_branch:
        return fail("Parent repository is in detached HEAD; checkout a branch first.")

    parent_pull = pull_repo(root)
    if parent_pull.returncode != 0:
        return fail(f"Parent pull failed on '{parent_branch}': {parent_pull.stderr or parent_pull.stdout}")

    info(f"OK   parent: pulled branch '{parent_branch}'.")

    pulled = 0
    errors = 0

    for module in modules:
        repo = root / module.path
        branch = target_branch_for_module(workspace, parent_branch, module)
        if not repo.exists() or not is_git_repository(repo):
            warn(f"{module.name}: repository missing or uninitialized; run './githelper init'.")
            errors += 1
            continue

        fetch_result = ensure_remote_refs(repo)
        if fetch_result.returncode != 0:
            warn(f"{module.name}: fetch failed: {fetch_result.stderr or fetch_result.stdout}")
            errors += 1
            continue

        switch_result = switch_to_branch(repo, branch)
        if switch_result.returncode != 0:
            warn(f"{module.name}: required branch '{branch}' not found: {switch_result.stderr or switch_result.stdout}")
            errors += 1
            continue

        pull_result = pull_repo(repo)
        if pull_result.returncode == 0:
            info(f"OK   {module.name}: pulled '{branch}'.")
            pulled += 1
        else:
            warn(f"{module.name}: pull failed on '{branch}': {pull_result.stderr or pull_result.stdout}")
            errors += 1

    info(f"Summary: pulled={pulled} errors={errors}")
    return 1 if errors else 0


def cmd_url_rewrite(args: argparse.Namespace) -> int:
    try:
        root = get_repo_root()
        workspace = load_workspace(root)
        modules = select_modules(workspace, args.modules)
        parser = read_manifest_parser(root)
    except RuntimeError as err:
        return fail(str(err))

    parent_changed = 0
    parent_unchanged = 0
    parent_skipped = 0

    parent_url_result = run_git(["remote", "get-url", "origin"], root)
    if parent_url_result.returncode != 0 or not parent_url_result.stdout:
        warn("parent: could not read 'origin' URL, skipping parent remote rewrite.")
        parent_skipped += 1
    else:
        parent_url = parent_url_result.stdout.strip()
        new_parent_url = rewrite_url(parent_url, args.to)
        if not new_parent_url:
            warn(f"parent: unsupported URL format '{parent_url}', skipping parent remote rewrite.")
            parent_skipped += 1
        elif new_parent_url == parent_url:
            info(f"OK   parent: already {args.to} ({parent_url})")
            parent_unchanged += 1
        else:
            info(f"PLAN parent: {parent_url} -> {new_parent_url}")
            if args.dry_run:
                parent_changed += 1
            else:
                parent_set = run_git(["remote", "set-url", "origin", new_parent_url], root)
                if parent_set.returncode != 0:
                    warn(f"parent: failed updating origin URL: {parent_set.stderr or parent_set.stdout}")
                    parent_skipped += 1
                else:
                    parent_changed += 1

    changed = 0
    unchanged = 0
    skipped = 0
    errors = 0

    for module in modules:
        new_url = rewrite_url(module.url, args.to)

        if not new_url:
            warn(f"{module.name}: unsupported URL format '{module.url}', skipping.")
            skipped += 1
            continue

        if new_url == module.url:
            info(f"OK   {module.name}: already {args.to} ({module.url})")
            unchanged += 1
            continue

        info(f"PLAN {module.name}: {module.url} -> {new_url}")
        if args.dry_run:
            changed += 1
            continue

        section = f"module.{module.name}"
        parser.set(section, "url", new_url)

        repo = root / module.path
        if repo.exists() and is_git_repository(repo):
            remote_set = run_git(["remote", "set-url", "origin", new_url], repo)
            if remote_set.returncode != 0:
                warn(f"{module.name}: failed updating origin URL: {remote_set.stderr or remote_set.stdout}")
                errors += 1
                continue

        changed += 1

    if not args.dry_run and changed:
        write_manifest_parser(root, parser)

    info(
        "Summary: "
        f"parent_changed={parent_changed} "
        f"parent_unchanged={parent_unchanged} "
        f"parent_skipped={parent_skipped} "
        f"modules_changed={changed} "
        f"modules_unchanged={unchanged} "
        f"modules_skipped={skipped} "
        f"errors={errors}"
        + (" (dry-run)" if args.dry_run else "")
    )
    return 1 if errors else 0


def parse_gitdir_file(git_file: Path) -> Optional[Path]:
    try:
        text = git_file.read_text(encoding="utf-8").strip()
    except OSError:
        return None

    match = re.match(r"^gitdir:\s*(.+)$", text)
    if not match:
        return None
    return Path(match.group(1).strip())


def collect_submodule_migration_items(root: Path, modules: Iterable[ModuleMeta]) -> List[MigrationItem]:
    items: List[MigrationItem] = []
    errors: List[str] = []

    for module in modules:
        module_path = root / module.path
        git_file = module_path / ".git"
        destination = module_path / ".git"

        if not module_path.exists():
            errors.append(f"{module.name}: module path does not exist: {module.path}")
            continue
        if destination.is_dir():
            errors.append(f"{module.name}: already has a .git directory; not a submodule worktree")
            continue
        if not git_file.is_file():
            errors.append(f"{module.name}: .git is not a gitdir file")
            continue

        relative_gitdir = parse_gitdir_file(git_file)
        if relative_gitdir is None:
            errors.append(f"{module.name}: .git file does not contain a gitdir pointer")
            continue

        gitdir = (module_path / relative_gitdir).resolve()
        expected = (root / ".git" / "modules" / module.path).resolve()
        if gitdir != expected:
            errors.append(f"{module.name}: gitdir points to {gitdir}, expected {expected}")
            continue
        if not gitdir.is_dir():
            errors.append(f"{module.name}: gitdir does not exist: {gitdir}")
            continue

        items.append(MigrationItem(module=module, git_file=git_file, gitdir=gitdir, destination=destination))

    if errors:
        raise RuntimeError("; ".join(errors))

    return items


def remove_submodule_config_sections(root: Path) -> int:
    result = run_git(["config", "--get-regexp", r"^submodule\."], root)
    if result.returncode != 0 or not result.stdout:
        return 0

    sections = []
    for line in result.stdout.splitlines():
        key = line.split(maxsplit=1)[0]
        section = key.rsplit(".", 1)[0]
        if section.startswith("submodule.") and section not in sections:
            sections.append(section)

    removed = 0
    for section in sections:
        remove_result = run_git(["config", "--remove-section", section], root)
        if remove_result.returncode == 0:
            removed += 1
    return removed


def cmd_migrate_from_submodules(args: argparse.Namespace) -> int:
    if not args.in_place:
        return fail("Only in-place migration is supported; pass --in-place.")

    try:
        root = get_repo_root()
        workspace = load_workspace(root)
        modules = select_modules(workspace, args.modules)
        items = collect_submodule_migration_items(root, modules)
    except RuntimeError as err:
        return fail(str(err))

    gitmodules = root / ".gitmodules"
    if not gitmodules.exists():
        return fail(".gitmodules not found; this does not look like a submodule workspace.")

    if working_tree_dirty(root):
        return fail("Parent repository has uncommitted changes; commit/stash them before migration.")

    for item in items:
        info(f"PLAN {item.module.name}: {item.gitdir} -> {item.destination}")

    if args.dry_run:
        info(f"Summary: modules={len(items)} errors=0 (dry-run)")
        return 0

    errors = 0
    for item in items:
        try:
            item.git_file.unlink()
            shutil.move(str(item.gitdir), str(item.destination))
        except OSError as exc:
            warn(f"{item.module.name}: could not move gitdir: {exc}")
            errors += 1
            continue

        unset_result = run_command(
            ["git", "config", "--file", str(item.destination / "config"), "--unset", "core.worktree"],
            root,
        )
        if unset_result.returncode not in (0, 5):
            warn(f"{item.module.name}: could not unset core.worktree: {unset_result.stderr or unset_result.stdout}")
            errors += 1
            continue

        info(f"OK   {item.module.name}: converted to standalone clone.")

    if errors:
        return fail(f"Migration stopped with errors={errors}.")

    paths = [item.module.path for item in items]
    remove_links = run_git(["rm", "--cached", "-r", "--ignore-unmatch", "--", *paths], root)
    if remove_links.returncode != 0:
        return fail(f"Could not remove gitlinks from parent index: {remove_links.stderr or remove_links.stdout}")

    remove_gitmodules = run_git(["rm", "--ignore-unmatch", ".gitmodules"], root)
    if remove_gitmodules.returncode != 0:
        return fail(f"Could not remove .gitmodules: {remove_gitmodules.stderr or remove_gitmodules.stdout}")

    removed_sections = remove_submodule_config_sections(root)
    info(
        "Summary: "
        f"modules={len(items)} "
        f"gitlinks_removed={len(paths)} "
        f"submodule_config_sections_removed={removed_sections} "
        "errors=0"
    )
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="githelper",
        description="Unified helper for parent repo + multi-repo workspace workflows.",
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    p_status = subparsers.add_parser("status", help="Show parent and module branch/HEAD status.")
    p_status.add_argument("--modules", help="Comma-separated module list. Defaults to all modules.")
    p_status.add_argument("--dirty", action="store_true", help="Show only repositories with local changes.")
    p_status.set_defaults(func=cmd_status)

    p_init = subparsers.add_parser("init", help="Clone missing workspace repositories from workspace.ini.")
    p_init.add_argument("--branch", help="Use the branch profile with this name while cloning.")
    p_init.add_argument("--modules", help="Comma-separated module list. Defaults to all modules.")
    p_init.set_defaults(func=cmd_init)

    p_sync = subparsers.add_parser(
        "sync",
        help="Sync modules to the current parent branch profile, or to module defaults if no profile exists.",
    )
    p_sync.add_argument("--branch", help="Target profile name. Defaults to parent current branch.")
    p_sync.add_argument("--modules", help="Comma-separated module list. Defaults to all modules.")
    p_sync.set_defaults(func=cmd_sync)

    p_switch = subparsers.add_parser(
        "switch",
        help="Switch parent branch and apply the matching workspace profile when present.",
    )
    p_switch.add_argument("branch", help="Target branch for the parent repository.")
    p_switch.add_argument("--modules", help="Comma-separated module list. Defaults to all modules.")
    p_switch.set_defaults(func=cmd_switch)

    p_pull = subparsers.add_parser(
        "pull",
        help="Pull parent branch, then pull modules on their workspace target branches.",
    )
    p_pull.add_argument("--branch", help="Parent branch to use before pulling.")
    p_pull.add_argument("--modules", help="Comma-separated module list. Defaults to all modules.")
    p_pull.set_defaults(func=cmd_pull)

    p_url = subparsers.add_parser("url", help="Rewrite parent/module URLs between SSH and HTTPS.")
    url_subparsers = p_url.add_subparsers(dest="url_command", required=True)
    p_url_rewrite = url_subparsers.add_parser("rewrite", help="Rewrite parent origin and selected module URLs.")
    p_url_rewrite.add_argument("--to", choices=("https", "ssh"), required=True, help="Target URL format.")
    p_url_rewrite.add_argument("--modules", help="Comma-separated module list. Defaults to all modules.")
    p_url_rewrite.add_argument(
        "--dry-run",
        action="store_true",
        help="Preview changes without writing workspace.ini or git remotes.",
    )
    p_url_rewrite.set_defaults(func=cmd_url_rewrite)

    p_branch = subparsers.add_parser("branch", help="Branch management for workspace modules.")
    branch_subparsers = p_branch.add_subparsers(dest="branch_command", required=True)

    p_branch_create = branch_subparsers.add_parser(
        "create",
        help="Create/switch branch in selected modules (defaults to current parent branch name).",
    )
    p_branch_create.add_argument(
        "--modules",
        required=True,
        help="Comma-separated module list (required).",
    )
    p_branch_create.add_argument(
        "--branch",
        help="Branch name. Defaults to parent current branch.",
    )
    p_branch_create.set_defaults(func=cmd_branch_create)

    p_migrate = subparsers.add_parser("migrate", help="Migration helpers for workspace layout changes.")
    migrate_subparsers = p_migrate.add_subparsers(dest="migrate_command", required=True)
    p_migrate_submodules = migrate_subparsers.add_parser(
        "from-submodules",
        help="Convert existing submodule worktrees into standalone clones.",
    )
    p_migrate_submodules.add_argument("--in-place", action="store_true", help="Convert the current worktree in place.")
    p_migrate_submodules.add_argument("--dry-run", action="store_true", help="Preview migration steps.")
    p_migrate_submodules.add_argument("--modules", help="Comma-separated module list. Defaults to all modules.")
    p_migrate_submodules.set_defaults(func=cmd_migrate_from_submodules)

    return parser


def main(argv: Optional[Sequence[str]] = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return int(args.func(args))


if __name__ == "__main__":
    sys.exit(main())
